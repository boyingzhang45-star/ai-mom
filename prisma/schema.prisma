generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  nickname  String   @default("孩子")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 认证
  email           String?   @unique
  phone           String?   @unique
  passwordHash    String?
  wechatOpenId    String?   @unique
  wechatUnionId   String?
  googleId        String?   @unique
  appleId         String?   @unique
  avatarUrl       String?

  motherProfile    MotherProfile?
  conversations    Conversation[]
  longTermMemories LongTermMemory[]

  // 订阅与额度
  subscriptionStatus String   @default("free")   // free | pro
  stripeCustId       String?                     // Stripe Customer ID
  stripeSubId        String?                     // Stripe Subscription ID
  subExpiresAt       DateTime?                   // Pro 到期时间
  freeMsgsUsed       Int      @default(0)        // 已用免费额度
  freeMsgsLimit      Int      @default(20)       // 免费额度上限

  subscription Subscription?
  payments     Payment[]
  msgUsage     MessageUsage?
}

model MotherProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  name        String   @default("妈妈")
  age         Int      @default(45)
  personality String   @default("gentle")
  avatarUrl         String?
  familyDescription String?
  createdAt         DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Conversation {
  id        String    @id @default(uuid())
  userId    String
  title     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id])
  messages Message[]
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  role           String
  content        String
  imageUrl       String?
  emotion        String?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model LongTermMemory {
  id          String   @id @default(uuid())
  userId      String
  category    String
  content     String
  importance  Int      @default(5)
  sourceMsgId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Subscription {
  id          String   @id @default(uuid())
  userId      String   @unique
  status      String   @default("free")    // free | active | cancelled | expired
  plan        String   @default("free")    // free | pro_monthly
  stripeSubId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Payment {
  id          String   @id @default(uuid())
  userId      String
  amount      Int                           // 金额（分）
  currency    String   @default("cny")
  status      String   @default("pending")  // pending | completed | failed
  stripePaymentIntentId String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model MessageUsage {
  id        String   @id @default(uuid())
  userId    String   @unique
  count     Int      @default(0)
  limit     Int      @default(20)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model ErrorLog {
  id        String   @id @default(uuid())
  level     String   @default("error")  // error | warn | info
  source    String                      // chat | auth | payment | upload | api
  message   String
  detail    String   @default("")
  userId    String   @default("")
  createdAt DateTime @default(now())
}
